generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client?
}

model Client {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique
  name              String
  startDate         DateTime
  initialInvestment Decimal  @db.Decimal(18,2)
  currentBalance    Decimal  @db.Decimal(18,2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
  allocations       OperationAllocation[]
}

model Operation {
  id               Int               @id @default(autoincrement())
  date             DateTime
  description      String
  eventName        String?
  market           String?
  odds             Decimal?          @db.Decimal(9,4)
  stakePct         Decimal?          @db.Decimal(9,4)
  resultPct        Decimal           @db.Decimal(9,4)
  outcome          OperationOutcome?
  settledAt        DateTime?
  notes            String?
  totalCapital     Decimal?          @db.Decimal(18,2)
  totalStakeAmount Decimal?          @db.Decimal(18,2)
  pnlAmount        Decimal?          @db.Decimal(18,2)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  allocations      OperationAllocation[]
  @@unique([date, description])
}

model OperationAllocation {
  id            Int      @id @default(autoincrement())
  operationId   Int
  clientId      Int
  balanceBefore Decimal  @db.Decimal(18,2)
  stakeAmount   Decimal  @db.Decimal(18,2)
  pnlAmount     Decimal  @db.Decimal(18,2)
  balanceAfter  Decimal  @db.Decimal(18,2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  operation     Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([operationId, clientId])
  @@index([clientId, operationId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  userId    Int?
  action    String
  details   String?
}

enum Role {
  ADMIN
  CLIENT
}

enum OperationOutcome {
  OPEN
  WON
  LOST
  VOID
}

