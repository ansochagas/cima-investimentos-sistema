{
  "name": "cima-backend",
  "version": "0.1.0",
  "description": "API do sistema CIMA Investimentos",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "npm run prisma:deploy:smart && node src/index.js",
    "seed": "node seed.js",
    "ledger:rebuild": "node rebuild-ledger.js",
    "smoke:api": "node smoke-api.js",
    "prisma:generate": "prisma generate",
    "prisma:baseline:initial": "prisma migrate resolve --applied 20260331_initial_schema",
    "prisma:deploy:smart": "node prisma-deploy-smart.js",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:deploy": "prisma migrate deploy",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@prisma/client": "^5.19.0",
    "@sentry/node": "^7.114.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^5.19.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "supertest": "^6.3.3"
  }
}
