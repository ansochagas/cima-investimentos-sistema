PORT=4000
NODE_ENV=production
DATABASE_PROVIDER=postgresql
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-second-long-random-secret
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=30d
CLIENT_ORIGIN=https://staging.cimainvest.com,http://127.0.0.1:8095
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
RATE_LIMIT_MAX=500
RATE_LIMIT_LOGIN_MAX=20

# Smoke check
SMOKE_BASE_URL=https://staging-api.cimainvest.com/api/v1
SMOKE_ADMIN_EMAIL=admin@cimainvest.com
SMOKE_ADMIN_PASSWORD=replace-me
SMOKE_CLIENT_EMAIL=joao@email.com
SMOKE_CLIENT_PASSWORD=replace-me
